# Binance Mainnet API Keys (Enable Futures permission, NO withdrawals)
CT_BINANCE_API_KEY=your_mainnet_api_key_here
CT_BINANCE_API_SECRET=your_mainnet_api_secret_here

# Binance Futures Testnet API Keys (https://testnet.binancefuture.com)
CT_BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
CT_BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# Trading Configuration
USE_TESTNET=True
TRADING_SYMBOL=BTC/USDT:USDT
TIMEFRAME=30m

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
